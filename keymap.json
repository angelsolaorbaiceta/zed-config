[
  {
    "context": "debugger_stopped > vim_mode == normal",
    "bindings": {
      "c": "debugger::Continue",
      "s": "debugger::StepOver",
      "S": "debugger::StepInto",
      "u": "debugger::StepOut",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "shift-enter": ["terminal::SendText", "\u001b\r"],
    },
  },
]
